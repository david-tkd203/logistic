# ── Django ──────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=

# ── Database (default: SQLite local, Postgres via Docker) ───────
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ── PostgreSQL (Docker Compose) ─────────────────────────────────
POSTGRES_DB=restologistics
POSTGRES_USER=restologistics
POSTGRES_PASSWORD=change-me

# ── Frontend (Vite) ─────────────────────────────────────────────
VITE_API_URL=http://<YOUR_IP>:8000/api

# ── CORS (production override) ──────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:80,http://localhost:5173
