# ── Django ──────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# ── Database (default: SQLite local, Postgres via Docker) ───────
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ── PostgreSQL (Docker Compose) ─────────────────────────────────
POSTGRES_DB=restologistics
POSTGRES_USER=restologistics
POSTGRES_PASSWORD=change-me
