# =============================================================================
# RestoLogistics — Variables de entorno para producción
# =============================================================================
# Copiá este archivo como .env para desarrollo local.
# En Dokploy configurá estas mismas variables en la UI del proyecto.
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_DB=restologistics
POSTGRES_USER=restologistics
POSTGRES_PASSWORD=cambiame_en_produccion

# ── Django ────────────────────────────────────────────────────────
# Generá una key única: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=cambiame_en_produccion
DJANGO_DEBUG=False

# Dominio/s donde se accede a la app (separados por coma)
DJANGO_ALLOWED_HOSTS=.tudominio.com,localhost

# Orígenes confiables para CSRF (misma URL base que el frontend)
DJANGO_CSRF_TRUSTED_ORIGINS=https://tudominio.com

# ── Base de datos (Django) ──────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=restologistics
DB_USER=restologistics
DB_PASSWORD=cambiame_en_produccion
DB_PORT=5432

# ── CORS (producción) ────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://tudominio.com
